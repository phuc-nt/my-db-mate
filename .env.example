# ─── LLM provider ───────────────────────────────────────────────
# Default provider = OpenRouter (BYOK). You can also pick a provider + paste a key
# in the app at /settings (stored encrypted). The env vars below are the fallback
# when nothing is configured in Settings.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3.7-max

# Optional: use OpenAI / Anthropic / Google directly instead of OpenRouter.
# Set LLM_PROVIDER to one of: openrouter | openai | anthropic | google.
# When set to a non-openrouter provider, the matching *_API_KEY + *_MODEL below
# are used (env fallback path — Settings still overrides env if configured there).
# NOTE: the *_MODEL values below are EXAMPLES — replace each with an exact model
# ID your account can access (they change over time and vary by account/tier).
LLM_PROVIDER=openrouter

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Google (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=...
GOOGLE_MODEL=gemini-3-flash

# ─── App storage ────────────────────────────────────────────────
# App DB (Postgres + pgvector) — connection string for My DB Mate's own storage
DATABASE_URL=postgres://mydbmate:mydbmate@localhost:5433/mydbmate

# AES-256-GCM key for encrypting target-DB credentials at rest (32-byte hex, e.g. `openssl rand -hex 32`)
CREDENTIAL_ENC_KEY=
